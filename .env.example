# Supabase（Project Settings > API）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Cloudflare R2（仅服务端使用，切勿添加 NEXT_PUBLIC_ 前缀）
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name

# R2 签名 URL 有效期，单位为秒；不填写时默认为 3600
R2_SIGNED_URL_EXPIRES_IN=3600

# 口语 AI 陪练服务
CONVERSATION_AI_BASE_URL=https://percent-tech-whilst-beings.trycloudflare.com
CONVERSATION_AI_CHAT_PATH=/chat
NEXT_PUBLIC_CONVERSATION_AI_WS_URL=wss://percent-tech-whilst-beings.trycloudflare.com/ws

# Qwen 的 DASHSCOPE_API_KEY 不要写在这里；请仅保存到 Supabase Edge Function Secret。
