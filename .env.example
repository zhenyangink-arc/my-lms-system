# Supabase（Project Settings > API）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Cloudflare R2（仅服务端使用，切勿添加 NEXT_PUBLIC_ 前缀）
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name

# R2 签名 URL 有效期，单位为秒；不填写时默认为 3600
R2_SIGNED_URL_EXPIRES_IN=3600

# 元智 AI 服务
YUANZHI_AI_BASE_URL=https://percent-tech-whilst-beings.trycloudflare.com
YUANZHI_AI_CHAT_PATH=/chat
NEXT_PUBLIC_YUANZHI_AI_WS_URL=wss://percent-tech-whilst-beings.trycloudflare.com/ws

# 元智 AI 高级版（兼容常见大模型对话接口；留空时页面显示“待接入”）
YUANZHI_AI_ADVANCED_API_URL=
YUANZHI_AI_ADVANCED_API_KEY=
YUANZHI_AI_ADVANCED_MODEL=
